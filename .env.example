# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Payment Gateway - Lahza (and legacy Stripe refs)
NEXT_PUBLIC_LAHZA_PUBLIC_KEY=pk_test_...
LAHZA_SECRET_KEY=sk_test_...
LAHZA_WEBHOOK_SECRET=your-webhook-secret

# Application Settings
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_KEY=your-secret-key-for-database-seeding
ADMIN_USER=Admin@
ADMIN_PASSWORD=Uptown@2026

# Optional: Stripe (if still using for other features)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Google reCAPTCHA
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-site-key
RECAPTCHA_SECRET_KEY=your-secret-key
